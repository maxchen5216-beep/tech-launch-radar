# 服务端口
PORT=8787

# 邮件驱动：mock（开发默认，仅记录日志不真实发送，验证码回显）| directmail（阿里云，生产推荐）| resend
MAIL_DRIVER=mock

# ---- 阿里云邮件推送 DirectMail（MAIL_DRIVER=directmail 时必填）----
# RAM 子账号 AccessKey（仅授权 AliyunDirectMailFullAccess）
ALIYUN_AK=
ALIYUN_SK=
# 已在 DirectMail 控制台验证的发信地址与发件人昵称
MAIL_FROM=noreply@mail.nextlaunch.cn
MAIL_FROM_ALIAS=科技圈发布会雷达

# ---- Resend（MAIL_DRIVER=resend 时必填）----
# RESEND_API_KEY=re_xxx

# JWT 密钥（生产环境必须设置随机值；不设置则自动生成并持久化到数据库）
# JWT_SECRET=

# 内部接口密钥（/internal/* 用，生产环境务必改为随机值）
INTERNAL_KEY=dev-internal-key

# 提醒邮件全局日上限（成本闸；DirectMail 免费额度为 200 封/天）
REMINDER_DAILY_CAP=180

# 管理员（逗号分隔）：可删除任何用户的评论。网页用 ADMIN_EMAILS，小程序用 ADMIN_OPENIDS
ADMIN_EMAILS=
ADMIN_OPENIDS=

# ---- 微信小程序（在 mp.weixin.qq.com 注册后填写；不填则小程序相关接口返回 503，不影响网页端）----
WX_APPID=
WX_SECRET=
WX_TEMPLATE_ID=    # 订阅消息模板 ID（功能→订阅消息 申请「活动提醒」模板后获取）
