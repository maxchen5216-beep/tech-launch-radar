# 服务端口
PORT=8787

# 邮件驱动：mock（默认，推送未上线，仅记录日志不真实发送）| resend | directmail
MAIL_DRIVER=mock

# 上线邮件推送时配置（二选一）：
# RESEND_API_KEY=re_xxx            # Resend（需已验证发信域名）
# ALIYUN_AK= / ALIYUN_SK=          # 阿里云邮件推送 DirectMail

# JWT 密钥（不设置则自动生成并持久化到数据库 meta 表）
# JWT_SECRET=

# 内部接口密钥（/internal/* 用，生产环境务必改掉）
INTERNAL_KEY=dev-internal-key

# 提醒邮件全局日上限（成本闸）
REMINDER_DAILY_CAP=500
