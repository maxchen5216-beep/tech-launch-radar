[Unit]
Description=Tech Launch Radar (科技圈发布会雷达)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tlr
WorkingDirectory=/opt/tlr/server
EnvironmentFile=/opt/tlr/server/.env
ExecStart=/home/tlr/.bun/bin/bun run src/index.ts
Restart=always
RestartSec=3
# 资源与安全限制
MemoryMax=512M
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/tlr

[Install]
WantedBy=multi-user.target
