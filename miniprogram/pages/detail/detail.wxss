.wrap { padding-top: 24rpx; padding-bottom: 60rpx; }
.name { font-size: 40rpx; font-weight: 800; }
.ename { font-size: 24rpx; margin-top: 6rpx; }
.date { font-size: 28rpx; margin-top: 16rpx; }
.org { font-size: 26rpx; margin-top: 6rpx; }
.summary { font-size: 27rpx; margin-top: 16rpx; line-height: 1.7; }
.row { display: flex; gap: 16rpx; margin-top: 22rpx; flex-wrap: wrap; }
.note { font-size: 22rpx; margin-top: 18rpx; line-height: 1.5; }

.sec-title { font-size: 30rpx; font-weight: 700; margin-bottom: 18rpx; }
.s-hint { font-size: 25rpx; margin-bottom: 16rpx; }
.lead-row { display: flex; gap: 16rpx; }
.lead { flex: 1; }
.subbed { font-size: 28rpx; }

.empty-c { font-size: 25rpx; padding: 16rpx 0 24rpx; }
.cmt { display: flex; gap: 18rpx; padding: 20rpx 0; border-bottom: 1rpx solid rgba(126,168,205,.1); }
.av-img { width: 56rpx; height: 56rpx; border-radius: 50%; }
.cmt-body { flex: 1; }
.cmt-meta { display: flex; align-items: center; gap: 16rpx; }
.cmt-nick { font-size: 26rpx; font-weight: 600; }
.cmt-time { font-size: 20rpx; }
.cmt-del { font-size: 22rpx; color: #5a6b7c; margin-left: auto; }
.cmt-text { font-size: 27rpx; margin-top: 6rpx; line-height: 1.6; word-break: break-all; }

.composer { margin-top: 24rpx; }
.cmt-input {
  width: 100%; box-sizing: border-box; background: #07090d;
  border: 1rpx solid rgba(126,168,205,.28); border-radius: 12rpx;
  padding: 18rpx 22rpx; font-size: 27rpx; color: #e8eef4; height: 120rpx;
}
.composer-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; }
