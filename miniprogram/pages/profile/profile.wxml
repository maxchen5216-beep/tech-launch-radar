<view class="page">
  <view class="head">我的</view>

  <!-- 未登录 -->
  <view wx:if="{{!loggedIn}}" class="login-box">
    <view class="muted">登录后可订阅提醒、参与评论</view>
    <view class="btn btn-primary btn-block" bindtap="onLogin" style="margin-top:30rpx">微信一键登录</view>
    <navigator url="" class="faint privacy">登录即同意隐私政策</navigator>
  </view>

  <!-- 已登录 · 编辑资料 -->
  <view wx:elif="{{editing}}" class="card">
    <view class="sec-title">{{profile.nickname ? '编辑资料' : '欢迎！完善你的资料'}}</view>
    <input class="nick-input" type="nickname" maxlength="20" placeholder="用户名（1-20字符）" placeholder-class="ph" value="{{nick}}" bindinput="onNick" />
    <view class="muted lbl">选择头像</view>
    <view class="grid">
      <view wx:for="{{presets}}" wx:key="*this"
        class="opt {{selAvatar === 'p:' + index ? 'sel' : ''}}"
        style="background:{{presetBg[index]}}" data-i="{{index}}" bindtap="pickPreset">{{item}}</view>
      <button wx:if="{{uploadPath}}" class="opt opt-img {{selAvatar === '__upload' ? 'sel' : ''}}" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image src="{{uploadPath}}" class="opt-img-i" />
      </button>
      <button wx:else class="opt opt-up" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">＋微信头像</button>
    </view>
    <view class="btn btn-primary btn-block" bindtap="onSave" style="margin-top:24rpx">完成</view>
  </view>

  <!-- 已登录 · 资料卡 -->
  <view wx:else>
    <view class="card profile-card">
      <view class="avatar big" style="{{av.type === 'emoji' ? 'background:' + av.bg : ''}}">
        <image wx:if="{{av.type === 'img'}}" src="{{av.value}}" class="big-img" />
        <text wx:else>{{av.value}}</text>
      </view>
      <view class="pname">{{profile.nickname}}</view>
      <view class="btn btn-ghost" bindtap="startEdit" style="margin-top:24rpx">编辑资料</view>
    </view>
    <view class="links">
      <view class="link" bindtap="onLogout">退出登录</view>
      <view class="link danger" bindtap="onDelete">注销账号</view>
    </view>
  </view>
</view>
