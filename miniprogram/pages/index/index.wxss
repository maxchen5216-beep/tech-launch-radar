.hero { padding: 40rpx 32rpx 16rpx; }
.eyebrow { color: #00e5a0; font-size: 22rpx; letter-spacing: 3rpx; }
.title { font-size: 56rpx; font-weight: 800; margin-top: 12rpx; }

.chips { white-space: nowrap; padding: 16rpx 24rpx; }
.chip {
  display: inline-block; padding: 12rpx 26rpx; margin-right: 14rpx;
  border-radius: 999rpx; font-size: 24rpx; color: #8294a6;
  border: 1rpx solid rgba(126,168,205,.28);
}
.chip.on { background: #e8eef4; color: #07090d; border-color: #e8eef4; }

.search { padding: 0 24rpx 20rpx; }
.search input {
  background: #0d1117; border: 1rpx solid rgba(126,168,205,.28);
  border-radius: 12rpx; padding: 18rpx 24rpx; color: #e8eef4; font-size: 26rpx;
}
.ph { color: #5a6b7c; }

.empty { text-align: center; color: #5a6b7c; padding: 80rpx 0; }

.topline { display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx; margin-bottom: 12rpx; }
.vmark { font-size: 20rpx; }
.cname { font-size: 34rpx; font-weight: 700; }
.cdate { font-size: 26rpx; margin-top: 12rpx; color: #e8eef4; }
.corg { font-size: 24rpx; margin-top: 4rpx; }
.csum { font-size: 26rpx; margin-top: 14rpx; line-height: 1.6; }
.cfoot { display: flex; gap: 16rpx; margin-top: 20rpx; flex-wrap: wrap; }
.card.past { opacity: .5; }

.tip { text-align: center; font-size: 22rpx; padding: 20rpx 0 50rpx; }
