<view class="page">
  <view class="head">我的提醒</view>

  <view wx:if="{{!loggedIn}}" class="login-box">
    <view class="muted">登录后管理你的发布会提醒</view>
    <view class="btn btn-primary btn-block" bindtap="onLogin" style="margin-top:30rpx">微信一键登录</view>
  </view>

  <block wx:else>
    <view wx:if="{{list.length === 0}}" class="empty muted">还没有订阅任何提醒，去「发布会」里订阅吧</view>
    <view wx:for="{{list}}" wx:key="event_id" class="card sub-item">
      <view class="sub-main" data-id="{{item.event_id}}" bindtap="goDetail">
        <view class="sub-name">{{item.name_zh || item.event_id}}</view>
        <view class="faint sub-meta">{{item.date_sort}} · {{item._modeText}}<text wx:if="{{item._fired}}" class="green"> · 已通知</text></view>
      </view>
      <view class="btn btn-ghost" data-id="{{item.event_id}}" bindtap="onCancel">取消</view>
    </view>
  </block>
</view>
